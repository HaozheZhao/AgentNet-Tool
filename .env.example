# CCAgent Annotator Environment Configuration
#
# Copy this file to .env and fill in your values:
#   Windows:  copy .env.example .env
#   Linux:    cp .env.example .env
#
# DO NOT commit .env to version control

# ==========================================
# Aliyun OSS Configuration (for cloud upload)
# ==========================================
# Required only if you want to upload recordings to the cloud.
# Leave as-is if you only need local recording and review.

OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id_here
OSS_ACCESS_KEY_SECRET=your_access_key_secret_here
OSS_BUCKET_NAME=your_bucket_name_here
